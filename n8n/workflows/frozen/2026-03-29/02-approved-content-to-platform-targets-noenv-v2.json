      "parameters": {
        "jsCode": "const item = $('Loop Items').item.json;\nconst map = { post: 'feed_post', reel: 'reel', story: 'story', tiktok_video: 'tiktok_post', carousel: 'feed_post' };\nconst format = map[item.content_type] || 'feed_post';\nreturn [{ json: { content_item_id: item.id, platform: item.primary_platform, account_ref: '', format, status: 'pending', scheduled_at: item.scheduled_at || null, published_at: null, platform_post_id: null, platform_post_url: null, error_message: null } }];"
