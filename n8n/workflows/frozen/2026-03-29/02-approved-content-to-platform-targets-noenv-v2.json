    {
      "parameters": {
        "jsCode": "const rows = Array.isArray($json.data) ? $json.data : [];\nreturn rows.filter(row => row.status === 'approved').filter(row => !!row.primary_platform).filter(row => row.content_type !== 'outreach_piece').map(row => ({ json: row }));"
